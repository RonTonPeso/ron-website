---
import type { Project } from "../data/projects";
import TerminalDemo from "./demos/TerminalDemo.astro";

// Map a project's `demo` key to its interactive component.
// Add new demos here as they are built (chess, charts, paint, ...).
const demoComponents: Record<string, any> = {
	terminal: TerminalDemo,
};

const { project } = Astro.props as { project: Project };
const ActiveDemo = project.demo ? demoComponents[project.demo] : null;
---

{ActiveDemo && <ActiveDemo />}
