---
import ProjectsGrid from "../components/ProjectsGrid.astro";
import { featuredProjects } from "../data/projects";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
	title="Ronnie Wang | Software Engineer"
	description="Ronnie Wang is a software engineer and University of Pennsylvania computer science student, passionate about AI, building projects across AI, systems, and infrastructure."
>
	<section class="hero" aria-labelledby="home-heading">
		<div class="hero-content">
			<h1 id="home-heading" class="hero-name">
				<span class="hero-line">Ronnie</span>
				<span class="hero-line">Wang</span>
			</h1>
			<p class="blurb hero-blurb">
				Software engineer passionate about <span class="hl-ai">AI</span>.
			</p>
			<div class="hero-meta" aria-hidden="true">
				<span class="meta-item">Philadelphia, PA</span>
				<span class="meta-sep"></span>
				<span class="meta-item">UPenn</span>
				<span class="meta-sep"></span>
				<span class="meta-item meta-status">
					<span class="status-dot"></span>AI/ML · Full-stack Development
				</span>
			</div>
			<div class="hero-actions" aria-label="Contact links">
				<a class="btn-primary" href="mailto:wronnie@seas.upenn.edu">
					<svg class="btn-icon" viewBox="0 0 24 24" aria-hidden="true">
						<path
							fill="currentColor"
							d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1h-2V8.24l-7 5.13-7-5.13V19H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm2.2 1L12 10.98 18.8 6H5.2Z"
						></path>
					</svg>
					Email
				</a>
				<a class="btn-ghost" href="https://github.com/RonTonPeso">
					<svg class="btn-icon" viewBox="0 0 16 16" aria-hidden="true">
						<path
							fill="currentColor"
							d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
						></path>
					</svg>
					GitHub
				</a>
				<a class="btn-penguin" href="#penguin" aria-label="Meet the penguin at the bottom of the page">
					<svg class="btn-icon penguin-glyph" viewBox="0 0 24 24" aria-hidden="true">
						<ellipse cx="12" cy="12.6" rx="6" ry="8" fill="#11202e"></ellipse>
						<ellipse cx="12" cy="14" rx="3.4" ry="5.6" fill="#eef7fb"></ellipse>
						<circle cx="9.7" cy="8.5" r="1.05" fill="#0a0f16"></circle>
						<circle cx="14.3" cy="8.5" r="1.05" fill="#0a0f16"></circle>
						<path d="M10.9 9.9h2.2L12 11.9z" fill="#f6a31f"></path>
					</svg>
					penguin!
				</a>
			</div>
		</div>
		<a class="hero-scroll" href="#projects">
			<span>Projects</span>
			<span class="scroll-line" aria-hidden="true"></span>
		</a>
	</section>

	<ProjectsGrid projects={featuredProjects} heading="Projects" />

	<section id="penguin" class="penguin-scene" aria-label="A cartoon penguin drifting on an ice floe">
		<p class="penguin-caption">Off the clock — drawn with nothing but CSS &amp; SVG.</p>
		<div class="penguin-stage">
			<div class="penguin-raft">
				<div class="raft-bob">
					<span class="penguin-shadow" aria-hidden="true"></span>

					<!-- ice floe: stacked faces for a 3D chunk -->
					<svg class="floe-art" viewBox="0 0 360 210" aria-hidden="true">
						<defs>
							<linearGradient id="ice-top" x1="0" y1="0" x2="0.3" y2="1">
								<stop offset="0%" stop-color="#ffffff"></stop>
								<stop offset="100%" stop-color="#cce8f2"></stop>
							</linearGradient>
							<linearGradient id="ice-front" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="#a9d2e2"></stop>
								<stop offset="100%" stop-color="#5a93b5"></stop>
							</linearGradient>
							<linearGradient id="ice-deep" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="rgba(150,221,242,0.55)"></stop>
								<stop offset="100%" stop-color="rgba(80,150,190,0)"></stop>
							</linearGradient>
						</defs>
						<path class="ice-underwater" d="M54 118 L196 156 L306 116 L262 188 L150 202 L78 160 Z" fill="url(#ice-deep)"></path>
						<path d="M54 84 L190 110 L306 82 L306 116 L196 156 L54 118 Z" fill="url(#ice-front)"></path>
						<path d="M54 84 L172 52 L306 82 L190 110 Z" fill="url(#ice-top)"></path>
						<path d="M54 84 L172 52 L306 82" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="2.5" stroke-linejoin="round"></path>
						<path d="M150 64 L176 96 M214 70 L196 104" stroke="rgba(120,170,195,0.45)" stroke-width="2" stroke-linecap="round"></path>
					</svg>

					<!-- the penguin -->
					<svg class="penguin-art" viewBox="0 0 220 260" aria-hidden="true">
						<defs>
							<radialGradient id="pg-body" cx="36%" cy="28%" r="78%">
								<stop offset="0%" stop-color="#3c4b5a"></stop>
								<stop offset="46%" stop-color="#1d2a39"></stop>
								<stop offset="100%" stop-color="#0b131c"></stop>
							</radialGradient>
							<radialGradient id="pg-belly" cx="42%" cy="32%" r="74%">
								<stop offset="0%" stop-color="#ffffff"></stop>
								<stop offset="68%" stop-color="#ecf5f8"></stop>
								<stop offset="100%" stop-color="#c2d7dd"></stop>
							</radialGradient>
							<linearGradient id="pg-beak" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="#ffd06b"></stop>
								<stop offset="100%" stop-color="#f59a1d"></stop>
							</linearGradient>
							<linearGradient id="pg-foot" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="#ffb43f"></stop>
								<stop offset="100%" stop-color="#e2811a"></stop>
							</linearGradient>
						</defs>

						<!-- feet -->
						<g class="pg-feet">
							<ellipse cx="86" cy="240" rx="23" ry="10" fill="url(#pg-foot)" transform="rotate(-9 86 240)"></ellipse>
							<ellipse cx="134" cy="240" rx="23" ry="10" fill="url(#pg-foot)" transform="rotate(9 134 240)"></ellipse>
						</g>

						<!-- body -->
						<path
							d="M110 30 C162 30 192 84 192 150 C192 212 158 248 110 248 C62 248 28 212 28 150 C28 84 58 30 110 30 Z"
							fill="url(#pg-body)"
						></path>

						<!-- aurora rim light on the cold edge -->
						<path
							d="M46 102 C54 66 80 42 110 38"
							fill="none"
							stroke="rgba(97,242,255,0.5)"
							stroke-width="4"
							stroke-linecap="round"
						></path>
						<!-- glossy specular highlight -->
						<ellipse cx="82" cy="92" rx="20" ry="29" fill="rgba(255,255,255,0.10)"></ellipse>

						<!-- flippers -->
						<ellipse class="pg-flipper pg-flipper-l" cx="36" cy="150" rx="15" ry="46" fill="#162331"></ellipse>
						<ellipse class="pg-flipper pg-flipper-r" cx="184" cy="150" rx="15" ry="46" fill="#162331"></ellipse>

						<!-- belly -->
						<ellipse cx="110" cy="160" rx="51" ry="71" fill="url(#pg-belly)"></ellipse>

						<!-- eyes -->
						<ellipse cx="90" cy="100" rx="11" ry="13.5" fill="#ffffff"></ellipse>
						<ellipse cx="130" cy="100" rx="11" ry="13.5" fill="#ffffff"></ellipse>
						<circle cx="93" cy="103" r="5.6" fill="#0a0f16"></circle>
						<circle cx="127" cy="103" r="5.6" fill="#0a0f16"></circle>
						<circle cx="95.2" cy="100.4" r="2" fill="#ffffff"></circle>
						<circle cx="129.2" cy="100.4" r="2" fill="#ffffff"></circle>

						<!-- beak -->
						<path d="M110 108 L124 117 L110 128 L96 117 Z" fill="url(#pg-beak)"></path>
					</svg>
				</div>
			</div>
			<div class="water" aria-hidden="true">
				<span class="bubble bubble-1"></span>
				<span class="bubble bubble-2"></span>
				<span class="bubble bubble-3"></span>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* ---- the playful penguin! button ---- */
	.btn-penguin {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		border-radius: 999px;
		padding: 0.82rem 1.45rem;
		border: 1px solid rgba(97, 242, 255, 0.55);
		background: rgba(97, 242, 255, 0.06);
		color: var(--cyan);
		font-family: "IBM Plex Mono", monospace;
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: lowercase;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease,
			background 180ms ease;
	}

	.btn-penguin:hover,
	.btn-penguin:focus-visible {
		transform: translateY(-2px);
		border-color: var(--cyan);
		background: rgba(97, 242, 255, 0.12);
		box-shadow: 0 14px 40px rgba(97, 242, 255, 0.22);
	}

	.btn-penguin .penguin-glyph {
		width: 1.15rem;
		height: 1.15rem;
		transition: transform 220ms ease;
	}

	.btn-penguin:hover .penguin-glyph {
		animation: penguin-wobble 0.6s ease-in-out;
	}

	/* ---- the scene ---- */
	.penguin-scene {
		position: relative;
		z-index: 1;
		width: 100%;
		min-height: 78vh;
		margin-top: 2rem;
		overflow: hidden;
	}

	.penguin-caption {
		margin: 0;
		padding-top: 1rem;
		color: var(--ink-soft);
		font-family: "IBM Plex Mono", monospace;
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-align: center;
		text-transform: uppercase;
	}

	.penguin-stage {
		position: absolute;
		inset: 0;
	}

	/* drifts across the middle half of the page (±25vw from center) */
	.penguin-raft {
		position: absolute;
		bottom: 17%;
		left: 50%;
		width: 320px;
		margin-left: -160px;
		animation: penguin-drift 17s ease-in-out infinite alternate;
		will-change: transform;
	}

	/* bob + rock, as if floating on water */
	.raft-bob {
		position: relative;
		height: 250px;
		transform-origin: center 78%;
		animation: raft-bob 4.6s ease-in-out infinite alternate;
	}

	.floe-art {
		position: absolute;
		bottom: 0;
		left: 50%;
		width: 300px;
		transform: translateX(-50%);
		filter: drop-shadow(0 10px 18px rgba(4, 14, 26, 0.5));
	}

	.penguin-art {
		position: absolute;
		bottom: 70px;
		left: 50%;
		width: 152px;
		transform: translateX(-50%);
		filter: drop-shadow(0 16px 22px rgba(3, 10, 20, 0.55));
	}

	/* soft contact shadow on the ice */
	.penguin-shadow {
		position: absolute;
		bottom: 96px;
		left: 50%;
		width: 120px;
		height: 22px;
		background: radial-gradient(closest-side, rgba(4, 14, 26, 0.45), transparent 75%);
		transform: translateX(-50%);
	}

	.pg-flipper {
		transform-origin: 50% 22%;
	}

	.pg-flipper-l {
		animation: flap-left 3.1s ease-in-out infinite alternate;
	}

	.pg-flipper-r {
		animation: flap-right 3.1s ease-in-out infinite alternate;
	}

	/* ---- water ---- */
	.water {
		position: absolute;
		right: 0;
		bottom: 0;
		left: 0;
		height: 30%;
		background: linear-gradient(
			180deg,
			rgba(20, 70, 104, 0) 0%,
			rgba(11, 41, 66, 0.6) 35%,
			rgba(4, 16, 30, 0.94) 100%
		);
		overflow: hidden;
	}

	/* waterline shimmer */
	.water::before {
		position: absolute;
		inset: 0 -10%;
		content: "";
		background: repeating-linear-gradient(
			92deg,
			transparent 0 28px,
			rgba(150, 230, 255, 0.07) 30px,
			rgba(150, 230, 255, 0.07) 34px,
			transparent 36px 70px
		);
		background-size: 200% 100%;
		mask-image: linear-gradient(to bottom, #000 0%, transparent 60%);
		-webkit-mask-image: linear-gradient(to bottom, #000 0%, transparent 60%);
		animation: ripple-shift 9s linear infinite;
	}

	/* thin glowing waterline */
	.water::after {
		position: absolute;
		top: 0;
		right: 0;
		left: 0;
		height: 2px;
		content: "";
		background: linear-gradient(90deg, transparent, rgba(97, 242, 255, 0.5), transparent);
	}

	.bubble {
		position: absolute;
		bottom: 8%;
		width: 7px;
		height: 7px;
		border: 1px solid rgba(180, 240, 255, 0.5);
		border-radius: 50%;
		opacity: 0;
	}

	.bubble-1 {
		left: 44%;
		animation: bubble-rise 6s ease-in 1.5s infinite;
	}

	.bubble-2 {
		left: 52%;
		width: 5px;
		height: 5px;
		animation: bubble-rise 7.5s ease-in 3.5s infinite;
	}

	.bubble-3 {
		left: 48%;
		width: 9px;
		height: 9px;
		animation: bubble-rise 8s ease-in 0.5s infinite;
	}

	@keyframes penguin-drift {
		from {
			transform: translateX(-25vw);
		}
		to {
			transform: translateX(25vw);
		}
	}

	@keyframes raft-bob {
		from {
			transform: translateY(2px) rotate(-2.4deg);
		}
		to {
			transform: translateY(-12px) rotate(2.4deg);
		}
	}

	@keyframes flap-left {
		from {
			transform: rotate(2deg);
		}
		to {
			transform: rotate(-12deg);
		}
	}

	@keyframes flap-right {
		from {
			transform: rotate(-2deg);
		}
		to {
			transform: rotate(12deg);
		}
	}

	@keyframes ripple-shift {
		from {
			background-position: 0 0;
		}
		to {
			background-position: 200% 0;
		}
	}

	@keyframes bubble-rise {
		0% {
			transform: translateY(0) scale(0.7);
			opacity: 0;
		}
		20% {
			opacity: 0.8;
		}
		100% {
			transform: translateY(-150px) scale(1);
			opacity: 0;
		}
	}

	@keyframes penguin-wobble {
		0%,
		100% {
			transform: rotate(0deg);
		}
		30% {
			transform: rotate(-14deg);
		}
		60% {
			transform: rotate(12deg);
		}
	}

	@media (max-width: 700px) {
		.penguin-raft {
			width: 240px;
			margin-left: -120px;
			bottom: 14%;
		}
		.floe-art {
			width: 230px;
		}
		.penguin-art {
			width: 116px;
			bottom: 54px;
		}
		.penguin-shadow {
			bottom: 74px;
			width: 92px;
		}
		.raft-bob {
			height: 200px;
		}
	}

	/* hold still and stay centered for reduced-motion */
	@media (prefers-reduced-motion: reduce) {
		.penguin-raft {
			transform: translateX(0) !important;
			animation: none !important;
		}
		.raft-bob,
		.pg-flipper-l,
		.pg-flipper-r,
		.water::before,
		.bubble {
			animation: none !important;
		}
	}
</style>
