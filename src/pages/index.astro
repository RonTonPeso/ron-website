---
import ProjectsGrid from "../components/ProjectsGrid.astro";
import { featuredProjects } from "../data/projects";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
	title="Ronnie Wang"
	description="Ronnie Wang is a software engineer passionate about AI and penguins."
>
	<section class="hero" aria-labelledby="home-heading">
		<div class="hero-aurora" aria-hidden="true"></div>
		<div class="hero-glow" aria-hidden="true"></div>
		<span class="hero-rail" aria-hidden="true">39.95&deg; N / 75.17&deg; W</span>
		<div class="hero-content">
			<p class="kicker hero-kicker">
				<span class="station-dot" aria-hidden="true"></span>Aurora field notes
			</p>
			<h1 id="home-heading" class="hero-name">
				<span class="hero-line">Ronnie</span>
				<span class="hero-line">Wang</span>
			</h1>
			<p class="blurb hero-blurb">
				Software engineer passionate about <span class="hl-ai">AI</span> and
				<span class="hl-peng">penguins</span>.
			</p>
			<div class="hero-meta" aria-hidden="true">
				<span class="meta-item">Philadelphia, PA</span>
				<span class="meta-sep"></span>
				<span class="meta-item">Penn Engineering</span>
				<span class="meta-sep"></span>
				<span class="meta-item meta-status">
					<span class="status-dot"></span>AI · Systems · Penguins
				</span>
			</div>
			<div class="hero-actions" aria-label="Contact links">
				<a class="btn-primary" href="mailto:wronnie@seas.upenn.edu">
					Email<span aria-hidden="true">&#8599;</span>
				</a>
				<a class="btn-ghost" href="https://github.com/RonTonPeso">
					GitHub<span aria-hidden="true">&#8599;</span>
				</a>
			</div>
		</div>
		<a class="hero-scroll" href="#projects">
			<span>Projects</span>
			<span class="scroll-line" aria-hidden="true"></span>
		</a>
	</section>

	<ProjectsGrid projects={featuredProjects} heading="Projects" />
</BaseLayout>
